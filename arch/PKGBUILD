# Maintainer: DaRipper91
pkgname=continuum-bin
pkgver=1.0.0
pkgrel=1
pkgdesc="Local-first AI Mind Map & Project Intelligence System"
arch=('any')
url="https://github.com/DaRipper91/contiinuum"
license=('MIT')
depends=('nodejs' 'npm')
makedepends=('npm')
source=("continuum.desktop" "continuum-runner.sh")
sha256sums=('SKIP' 'SKIP')

build() {
  # Build from the local directory where makepkg is run
  cd "$srcdir/.."
  npm install
  npm run build
}

package() {
  # Install the built files
  install -d "$pkgdir/usr/lib/continuum"
  cp -r "$srcdir/../dist/"* "$pkgdir/usr/lib/continuum/"
  
  # Install the runner
  install -Dm755 "$srcdir/continuum-runner.sh" "$pkgdir/usr/bin/continuum-runner"
  
  # Install desktop entry
  install -Dm644 "$srcdir/continuum.desktop" "$pkgdir/usr/share/applications/continuum.desktop"
  
  # Install icon (using the termuxvoid logo)
  # Note: Assets directory is outside arch/
  if [ -f "$srcdir/../assets/termuxvoid_logo.png" ]; then
    install -Dm644 "$srcdir/../assets/termuxvoid_logo.png" "$pkgdir/usr/share/icons/hicolor/512x512/apps/continuum.png"
  fi
}
